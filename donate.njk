                <p>Support the Malayalam Christian music community</p>
            </div>
        </div>
    </div>
</section>

<section class="faq-section">
    <div class="container">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-grid">
            <article class="faq-card">
                <h3>Is my donation secure?</h3>
                <p>Yes! UPI payments are secured by your bank's encryption and authentication.</p>
            </article>
            <article class="faq-card">
                <h3>Do you accept international donations?</h3>
                <p>Currently we accept UPI and bank transfers within India. Contact us for international options.</p>
            </article>
            <article class="faq-card">
                <h3>Can I get a tax deduction?</h3>
                <p>We're working on 80G certification. Please contact us for details.</p>
            </article>
            <article class="faq-card">
                <h3>How will my donation be used?</h3>
                <p>All donations go directly to creating more tutorials, improving video quality, and maintaining the website.</p>
            </article>
        </div>
    </div>
</section>

<script>
// UPI Payment Configuration - injected from environment at build time
const UPI_CONFIG = {
    // UPI ID is injected from environment variables during build
    upiId: '{{ env.UPI_ID | default("yourname@bankname") }}',
    merchantName: '{{ env.UPI_MERCHANT_NAME | default("Mindful Living & Devotional Music") }}',
    transactionNote: 'Support for Malayalam Christian Music Tutorials',
    currency: 'INR'
};

function openUPIPayment() {
    // Get the amount if user has selected one
    const amount = document.getElementById('donation-amount')?.value || '';
    
    // Create UPI payment URL
    const upiUrl = `upi://pay?pa=${UPI_CONFIG.upiId}&pn=${encodeURIComponent(UPI_CONFIG.merchantName)}&tn=${encodeURIComponent(UPI_CONFIG.transactionNote)}&cu=${UPI_CONFIG.currency}`;
    
    // Try to open UPI app
    const isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
    
    if (isMobile) {
        // On mobile, try to open UPI app
        window.location.href = upiUrl;
        
        // If that doesn't work, show manual instructions
        setTimeout(() => {
            alert(`Please open your UPI app and pay to:\nUPI ID: ${UPI_CONFIG.upiId}\nAmount: ${amount || 'As you wish'}\nNote: ${UPI_CONFIG.transactionNote}`);
        }, 1000);
    } else {
        // On desktop, show instructions
        alert(`To donate via UPI:\n\n1. Open your UPI app (PhonePe, Paytm, Google Pay, etc.)\n2. Pay to UPI ID: ${UPI_CONFIG.upiId}\n3. Enter amount: ${amount || 'As you wish'}\n4. Note: ${UPI_CONFIG.transactionNote}\n\nThank you for your support! 🙏`);
    }
}

// Track donation clicks (for analytics)
document.getElementById('upi-pay-btn')?.addEventListener('click', function() {
    console.log('Donation button clicked');
    // Add analytics tracking here if needed
});
</script>
