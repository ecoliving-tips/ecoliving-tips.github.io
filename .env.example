# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION (Required)
# -----------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard > Your Project > Settings > API

# Your Supabase project URL (e.g., https://xyzabc123.supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (starts with eyJ...)
SUPABASE_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# UPI PAYMENT CONFIGURATION (Required for donations)
# -----------------------------------------------------------------------------

# Your UPI ID (e.g., yourname@oksbi, yourname@upi)
UPI_ID=yourname@bankname

# Display name for UPI transactions
UPI_MERCHANT_NAME=Mindful Living & Devotional Music

# -----------------------------------------------------------------------------
# SITE CONFIGURATION (Optional)
# -----------------------------------------------------------------------------

# Your site's full URL (for SEO and canonical links)
SITE_URL=https://ecoliving-tips.github.io

# =============================================================================
# HOW TO GET THESE VALUES
# =============================================================================

# SUPABASE_URL & SUPABASE_KEY:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings (gear icon) > API
# 4. Copy "Project URL" to SUPABASE_URL
# 5. Copy "anon public" key to SUPABASE_KEY

# UPI_ID:
# Your UPI ID is what you use to receive UPI payments
# Common formats: name@bankname, name@upi, mobilenumber@upi
# Examples: john@oksbi, 9876543210@upi
