        </div>
    </div>
</section>

<section class="request-cta">
    <div class="container">
        <div class="request-cta-content">
            <h2>Can't find your song?</h2>
            <p>We're constantly adding new songs based on user requests</p>
            <a href="/request/" class="btn">Request a Song</a>
        </div>
    </div>
</section>

<script>
// Initialize songs data
let allSongs = [];
let filteredSongs = [];
let currentCategory = 'all';
let searchQuery = '';

document.addEventListener('DOMContentLoaded', function() {
    // Load songs from database
    loadSongs();
    
    // Setup search
    const searchInput = document.getElementById('song-search');
    searchInput?.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            searchSongs();
        }
    });
    
    // Setup category filters
    const categoryBtns = document.querySelectorAll('.category-btn');
    categoryBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            // Update active state
            categoryBtns.forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            
            // Filter by category
            currentCategory = this.dataset.category;
            filterSongs();
        });
    });
});

async function loadSongs() {
    const grid = document.getElementById('songs-grid');
    const loading = document.getElementById('loading');
    
    loading.style.display = 'block';
    
    // Try to load from Supabase if configured
    if (typeof SongAPI !== 'undefined') {
        try {
            allSongs = await SongAPI.getSongs();
            if (allSongs && allSongs.length > 0) {
                renderSongs(allSongs);
                return;
            }
        } catch (error) {
            console.log('Using static fallback content');
        }
    }
    
    // Use static content (fallback)
    loading.style.display = 'none';
    console.log('Showing static song content');
}

function renderSongs(songs) {
    const grid = document.getElementById('songs-grid');
    const noSongs = document.getElementById('no-songs');
    const count = document.getElementById('songs-count');
    const loading = document.getElementById('loading');
    
    loading.style.display = 'none';
    
    if (!songs || songs.length === 0) {
        grid.style.display = 'none';
        noSongs.style.display = 'block';
        return;
    }
    
    grid.style.display = 'grid';
    noSongs.style.display = 'none';
    
    count.textContent = `Showing ${songs.length} song${songs.length !== 1 ? 's' : ''}`;
    
    // Use DocumentFragment for better performance and XSS prevention
    const fragment = document.createDocumentFragment();
    
    songs.forEach(song => {
        const article = document.createElement('article');
        article.className = 'song-card';
        article.dataset.category = song.category || 'all';
        
        // Use textContent to prevent XSS attacks
        const h3 = document.createElement('h3');
        h3.textContent = song.title || 'Untitled';
        article.appendChild(h3);
        
        const p = document.createElement('p');
        p.textContent = song.description || 'Learn this beautiful Malayalam Christian devotional song on keyboard.';
        article.appendChild(p);
        
        const detailsDiv = document.createElement('div');
        detailsDiv.className = 'song-details';
        
        const difficultySpan = document.createElement('span');
        difficultySpan.className = 'difficulty';
        difficultySpan.textContent = song.difficulty || 'All Levels';
        detailsDiv.appendChild(difficultySpan);
        
        const viewsSpan = document.createElement('span');
        viewsSpan.className = 'views';
        viewsSpan.textContent = formatViews(song.views) + ' views';
        detailsDiv.appendChild(viewsSpan);
        
        article.appendChild(detailsDiv);
        
        const link = document.createElement('a');
        if (song.youtube_video_id) {
            link.href = 'https://youtu.be/' + encodeURIComponent(song.youtube_video_id);
            link.target = '_blank';
            link.className = 'song-link';
            link.textContent = 'Watch Tutorial';
        } else {
            link.href = '/request/';
            link.className = 'song-link';
            link.textContent = 'Coming Soon';
        }
        article.appendChild(link);
        
        fragment.appendChild(article);
    });
    
    grid.innerHTML = '';
    grid.appendChild(fragment);
}

function filterSongs() {
    let songs = allSongs;
    
    // Filter by category
    if (currentCategory !== 'all') {
        songs = songs.filter(s => s.category === currentCategory);
    }
    
    // Filter by search
    if (searchQuery) {
        const query = searchQuery.toLowerCase();
        songs = songs.filter(s => 
            (s.title && s.title.toLowerCase().includes(query)) ||
            (s.title_english && s.title_english.toLowerCase().includes(query))
        );
    }
    
    renderSongs(songs);
}

function searchSongs() {
    const searchInput = document.getElementById('song-search');
    searchQuery = searchInput.value.trim();
    filterSongs();
}

function formatViews(views) {
    if (!views) return '0';
    if (views >= 1000) {
        return (views / 1000).toFixed(0) + 'K';
    }
    return views.toString();
}
</script>
