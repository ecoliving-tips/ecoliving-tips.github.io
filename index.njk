layout: base.njk
title: Home
description: Learn Malayalam Christian devotional songs on keyboard with easy step-by-step tutorials. Master Syro Malabar Holy Mass songs with chord progressions, playing techniques, and background music arrangements for church worship.
---

    <main>
        <section id="home" class="hero">
            <div class="container">
                <div class="hero-content">
                    <h2>Learn Syro Malabar Holy Mass Songs</h2>
                    <p>Master beautiful Malayalam Syro Malabar liturgical songs on keyboard with our easy-to-follow
                        tutorials.
                        Learn traditional holy mass songs with chord progressions, playing techniques, and background
                        music for church worship.</p>
                    <div class="hero-buttons">
                        <a href="https://www.youtube.com/@almightyone8205" target="_blank" rel="noopener noreferrer"
                            class="btn youtube-btn">
                            🎵 Watch Tutorials on YouTube
                        </a>
                        <a href="/songs/" class="btn btn-secondary">Browse Holy Mass Songs</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- AdSense Ad Unit -->
        <div class="adsense-banner">
            <ins class="adsbygoogle"
                style="display:block"
                data-ad-client="ca-pub-7438590583270235"
                data-ad-slot="1234567890"
                data-ad-format="auto"
                data-full-width-responsive="true"></ins>
        </div>

        <section id="tutorials" class="tutorials-section">
            <div class="container">
                <h2>Syro Malabar Holy Mass Tutorial Categories</h2>
                <div class="tutorials-grid">
                    {% for category in metadata.categories %}
                    <article class="tutorial-card">
                        <div class="tutorial-icon">{{ category.icon }}</div>
                        <h3>{{ category.name }}</h3>
                        <p>{{ category.description }}</p>
                        <a href="/songs/?category={{ category.id }}"
                            class="read-more">Browse {{ category.name }}</a>
                    </article>
                    {% endfor %}
                </div>
            </div>
        </section>

        <!-- AdSense Ad Unit -->
        <div class="adsense-banner">
            <ins class="adsbygoogle"
                style="display:block"
                data-ad-client="ca-pub-7438590583270235"
